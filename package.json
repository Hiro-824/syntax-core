{
    "name": "syntax-core",
    "version": "0.1.0",
    "description": "Core TypeScript library for parsing and grammar-related logic.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "tsx src/demo.ts",
        "build": "tsc",
        "check": "tsc --noEmit",
        "test": "npm run build && node dist/hpsg.test.js",
        "clean": "rimraf dist",
        "prepare": "npm run build"
    },
    "devDependencies": {
        "rimraf": "^6.0.1",
        "tsx": "^4.20.5",
        "typescript": "^5.8.2"
    }
}
